<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bdqn.class7.springboot.dms.mapper.RepairMapper">

    <resultMap id="RepairVo" type="com.bdqn.class7.springboot.dms.entity.Repair">
        <id column="id" property="id"/>
        <result column="dormitory_id" property="dormitoryId"/>
        <result column="student_id" property="studentId"/>
        <result column="content" property="content"/>
        <result column="status" property="status"/>
        <result column="apply_time" property="applyTime"/>
        <result column="student_name" property="studentName"/>
        <result column="building_name" property="buildingName"/>
        <result column="room_number" property="roomNumber"/>
    </resultMap>

    <select id="pageWithDetail" resultMap="RepairVo">
        SELECT r.*, s.name AS student_name, b.name AS building_name, d.room_number
        FROM bus_repair r
        LEFT JOIN bus_student s ON s.id = r.student_id
        LEFT JOIN bus_dormitory d ON d.id = r.dormitory_id
        LEFT JOIN bus_building b ON b.id = d.building_id
        <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
            ${ew.customSqlSegment}
        </if>
    </select>
</mapper>
